<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>한동대학교 동아리</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f5f7fa;
}

.container{
    width:90%;
    max-width:1200px;
    margin:auto;
    padding:30px;
}

/* 헤더 */
header{
    background:#0B1F4D;
    color:white;
    padding:25px;
    border-radius:15px;
    text-align:center;
    margin-bottom:30px;
}

.header-content{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:20px;
}

header h1{
    font-size:40px;
    color:white;
}

.logo{
    width:60px;
    height:60px;
    object-fit:contain;
    background:white;
    border-radius:50%;
    padding:3px;
    transition:0.3s;
}

.logo:hover{
    transform:scale(1.08);
}

/* 검색창 */
.search-container{
    display:flex;
    justify-content:center;
    margin-bottom:20px;
}

.search-box{
    width:500px;
    padding:12px;
    border:3px solid #0B1F4D;
    border-radius:25px;
}

.search-box:focus{
    outline:none;
    box-shadow:0 0 10px rgba(11,31,77,0.3);
}

/* 카테고리 */
.categories{
    display:flex;
    justify-content:center;
    gap:25px;
    margin-bottom:30px;
}

.category{
    font-size:30px;
    cursor:pointer;
    transition:0.3s;
}

.category:hover{
    transform:scale(1.2);
    color:#0B1F4D;
}

/* 달력 */
.calendar{
    width:100%;
    height:auto;
    background:white;
    border:2px solid #d0d8e8;
    border-radius:15px;
    padding:20px;
    margin-bottom:40px;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
}

.calendar h2{
    color:#0B1F4D;
    margin-bottom:10px;
}

.calendar table{
    width:100%;
    border-collapse:collapse;
    text-align:center;
    margin-top:15px;
}

.calendar caption{
    font-size:20px;
    font-weight:bold;
    margin-bottom:10px;
    color:#0B1F4D;
}

.calendar th{
    background:#0B1F4D;
    color:white;
    padding:12px;
}

.calendar td{
    height:80px;
    padding:10px;
    background:#f8faff;
    transition:0.3s;
}

.calendar td:hover{
    background:#dbe4ff;
}

/* 동아리 카드 */
.club-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
}

.club-card{
    background:white;
    padding:20px;
    border-radius:12px;
    text-align:center;
    box-shadow:0 0 8px rgba(0,0,0,0.1);
    transition:0.3s;
    border-top:5px solid #0B1F4D;
}

.club-card:hover{
    transform:translateY(-8px);
    background:#0B1F4D;
}

.club-logo{
    width:100px;
    height:100px;
    margin:auto;
    background:#dbe4ff;
    border-radius:10px;
    margin-bottom:10px;
}

.club-card a{
    text-decoration:none;
    color:black;
}

.club-card h3{
    margin-top:10px;
}

.club-card:hover h3,
.club-card:hover a{
    color:white;
}

/* 반응형 */
@media(max-width:768px){
    .header-content{
        flex-direction:column;
    }

    header h1{
        font-size:30px;
    }

    .search-box{
        width:100%;
    }

    .categories{
        flex-wrap:wrap;
    }

    .category{
        font-size:25px;
    }

    .calendar td{
        height:60px;
        font-size:12px;
        padding:5px;
    }
}
</style>
</head>

<body>

<div class="container">

    <header>
        <div class="header-content">
            <a href="index.html">
                <img src="https://i.namu.wiki/i/CYsXdQdGlOACqAG_NoN45qvEC71vaRicVOSsLXnDVYyGLa_tQnjI7UdcY1XAXYbmoXLxmD8kaMCBTCOhHgnfMg.svg"
                alt="Handong Logo"
                class="logo">
            </a>

            <h1>한동대학교 동아리 소개</h1>
        </div>
    </header>

    <div class="search-container">
        <input type="text" class="search-box" placeholder="Search Club...">
    </div>

    <div class="categories">
        <div class="category">🎵</div>
        <div class="category">🏃</div>
        <div class="category">🎨</div>
        <div class="category">❤️</div>
        <div class="category">✝️</div>
        <div class="category">📄</div>
    </div>

    <section class="calendar">
        <h2>📅 동아리 일정표</h2>

        <table border="1">
            <caption> 6월 동아리 일정표</caption>

            <tr>
                <th>Sun</th>
                <th>Mon</th>
                <th>Tue</th>
                <th>Wed</th>
                <th>Thu</th>
                <th>Fri</th>
                <th>Sat</th>
            </tr>

            <tr>
                <td></td>
                <td>1</td>
                <td>2</td>
                <td>3</td>
                <td>4</td>
                <td>5<br>⚽ 차요차요</td>
                <td>6</td>
            </tr>

            <tr>
                <td>7</td>
                <td>8</td>
                <td>9</td>
                <td>10<br>🎭 꾼들</td>
                <td>11</td>
                <td>12</td>
                <td>13</td>
            </tr>

            <tr>
                <td>14</td>
                <td>15<br>🤝 </td>
                <td>16</td>
                <td>17</td>
                <td>18</td>
                <td>19</td>
                <td>20</td>
            </tr>

            <tr>
                <td>21</td>
                <td>22<br>✝ 예배</td>
                <td>23</td>
                <td>24</td>
                <td>25<br>🎨 팔레트</td>
                <td>26</td>
                <td>27</td>
            </tr>

            <tr>
                <td>28</td>
                <td>29</td>
                <td>30</td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
        </table>
    </section>

    <section class="club-grid">

        <div class="club-card">
            <a href="club1.html">
                <div class="club-logo"></div>
                <h3>God's Fellow</h3>
            </a>
        </div>

        <div class="club-card">
            <a href="club2.html">
                <div class="club-logo"></div>
                <h3>하늘을 향한 춤</h3>
            </a>
        </div>

        <div class="club-card">
            <a href="club3.html">
                <div class="club-logo"></div>
                <h3>소울</h3>
            </a>
        </div>

        <div class="club-card">
            <a href="club4.html">
                <div class="club-logo"></div>
                <h3>한풍</h3>
            </a>
        </div>

    </section>

</div>

</body>
